# Database (local dev defaults; Docker Compose overrides to /data)
DATABASE_URL=sqlite+aiosqlite:///./data/ccas.db

# Telegram (required)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=

# Gmail (required; local dev defaults resolve under backend/data)
GMAIL_CREDENTIALS_PATH=./data/credentials.json
GMAIL_TOKEN_PATH=./data/token.json
STAGING_DIR=./data/staging

# API (required)
API_TOKEN=
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://localhost

# Session (optional, defaults shown)
# API_SESSION_COOKIE_NAME=ccas_session
# API_SESSION_MAX_AGE=43200
# API_COOKIE_SECURE=False

# Redis
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Bank PDF Passwords (per-bank, pattern: PDF_PASSWORD_<BANK_CODE>)
# PDF_PASSWORD_CTBC=your-ctbc-password
# PDF_PASSWORD_CATHAY=your-cathay-password

# Frontend (Vite -- VITE_ prefix required)
# VITE_API_BASE=http://127.0.0.1:8000
