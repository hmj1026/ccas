# =============================================================================
# CCAS env file（SSOT 範本）
# =============================================================================
# 規則：
#   - `KEY=`（無預設值）→ **必填**：未設定會在啟動時 fail-fast
#   - `KEY=value`（有預設值）→ 選填：未設定僅 WARN，使用 .env.example 的預設值
#   - `# KEY=...`（整行註解）→ 完全選填：不會被 check-env.sh 視為任何要求
# =============================================================================

# -----------------------------------------------------------------------------
# Docker / 部署 — 僅 prod compose（docker/docker-compose.yml）會用到
# 本機 dev (`docker compose up`) 不需要設定下列變數
# -----------------------------------------------------------------------------
CCAS_VERSION=release                  # GHCR image tag；建議 production 改 vX.Y.Z 精確版本
CCAS_DATA_LOCATION=./data             # 持久化資料目錄（SQLite / staging / secrets / redis dump）
CCAS_CONFIG_LOCATION=./config         # banks.yaml / categories.yaml / bank-code-registry.yaml 目錄
CCAS_LOG_LOCATION=./logs              # 各 service log 檔目錄
CCAS_PORT=8080                        # Proxy 對外 host port（同時即 Web UI 入口）；範圍 1-65535
# PUBLIC_BASE_URL=http://localhost:8080 # OAuth redirect URI 用；自訂 CCAS_PORT / 網域時同步調整
# REPO_OWNER=                          # GHCR namespace（如 hmj1026）；prod compose 需設定，dev 不用

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/ccas.db

# -----------------------------------------------------------------------------
# Telegram（選填；未填則 bot 進入 disabled idle 狀態，notify 階段跳過）
# -----------------------------------------------------------------------------
# Bot API token（從 @BotFather 的 /newbot 取得）。
# TELEGRAM_BOT_TOKEN=your-bot-token
# 通知目標 chat ID。執行 ./scripts/get-telegram-chat-id.sh 取得。
# 留空則 notify 階段不發送通知，其他階段不受影響。
# TELEGRAM_CHAT_ID=your-chat-id
# 允許使用 bot 指令的 chat ID 白名單，逗號分隔。
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890

# -----------------------------------------------------------------------------
# Gmail（必填；本機 dev 預設指向 backend/data）
# -----------------------------------------------------------------------------
GMAIL_CREDENTIALS_PATH=./data/credentials.json
GMAIL_TOKEN_PATH=./data/token.json
STAGING_DIR=./data/staging

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# API_TOKEN：未設定時 entrypoint 自動產生 32-byte hex 並落地 ${CCAS_DATA_LOCATION}/secrets/api-token；
# 顯式設為空字串會被 check-env.sh 報錯（避免「忘了取消註解」造成的弱密碼）
# API_TOKEN=
API_HOST=0.0.0.0
API_PORT=8000
# ENABLE_API_DOCS：是否啟用 Swagger UI（/docs）、ReDoc（/redoc）與 /openapi.json。
# 預設 false（production 不暴露 API surface）；僅開發或內部除錯時改 true。
# ENABLE_API_DOCS=false
# FRONTEND_ORIGINS：CORS 來源白名單（逗號分隔）。
#   - prod 同源（前後端皆走 ${CCAS_PORT}）→ 可留空（prod compose proxy 已收斂為單一入口）
#   - 開發用本機 5173/8080 雙 server 時填以下值
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8080,http://localhost:8080,http://localhost

# Session（選填，下方為預設值）
# API_SESSION_COOKIE_NAME=ccas_session
# API_SESSION_MAX_AGE=43200
# API_COOKIE_SECURE：生產環境應設 true (HTTPS)；cookie 加 Secure 旗標只在 TLS 連線送出。
# 僅以 HTTP 存取的本機 dev 請維持註解／false，否則 cookie 不會送出（後端預設 False）。
# check-env.sh 會在 PUBLIC_BASE_URL 為 https:// 但此值非 true 時發出非阻斷警告。
# API_COOKIE_SECURE=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# REDIS_URL：未設定時後端預設 redis://localhost:6379/0（本機 pip 模式）；
# Docker Compose 容器內預設 redis://redis:6379/0（由 compose 注入，不需在此設定）。
# 僅在自訂 Redis 位置或啟用 REDIS_PASSWORD 時取消註解；
# 啟用密碼時格式為 redis://:your-password@redis:6379/0（Docker）或 @localhost（本機）。
# 注意：Docker 部署時請勿在 .env 設定 localhost——compose 會將此值注入容器，
# 容器內 localhost 連不到 redis service。
# REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD：設定後 docker compose 以 --requirepass 啟動 redis 並套用於
# healthcheck / redis-commander；同時「必須」把密碼寫進 REDIS_URL（見上）供
# backend / worker / scheduler 連線。留空或不設定 = 無密碼。
#   - dev / 單機（redis 僅綁 127.0.0.1）：留空可接受
#   - production / redis 可被其他主機觸及：建議設定（check-env.sh 會在留空時非阻斷警告）
# 範例（取消註解並改成實際強密碼）：
# REDIS_PASSWORD=change-me-strong-password
# Docker Compose redis service resource tuning（僅 Docker 部署時使用；本機 pip 模式忽略）
# REDIS_MAXMEMORY=256mb              # 容器內 redis 記憶體上限；可依部署環境調整（預設 256mb）
# REDIS_MAXMEMORY_POLICY=allkeys-lru
# eviction 策略（預設 allkeys-lru）；常用選項：
#   allkeys-lru   — 任何 key 都可被 LRU 淘汰（cache 場景首選）
#   allkeys-lfu   — 任何 key 都可被 LFU 淘汰（命中率分布不均時更佳）
#   volatile-lru  — 僅淘汰設過 TTL 的 key
#   noeviction    — 滿了直接拒寫（CCAS 不建議：RQ enqueue 會失敗）
# 完整文件：https://redis.io/docs/latest/develop/reference/eviction/

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_DIR=                   # 日誌檔案目錄（空字串=僅 stdout，不寫檔）
# LOG_FILE_MAX_BYTES=10485760  # 單檔上限（預設 10 MB）
# LOG_FILE_BACKUP_COUNT=5     # 保留備份數
# LOG_FILE_PREFIX=ccas         # 日誌檔名前綴（產生 {prefix}.log）

# -----------------------------------------------------------------------------
# Bank PDF Passwords（per-bank，pattern: PDF_PASSWORD_<BANK_CODE>）
# -----------------------------------------------------------------------------
# PDF_PASSWORD_CTBC=your-ctbc-password
# PDF_PASSWORD_ESUN=your-password
# PDF_PASSWORD_TAISHIN=your-password # 身分證字號後2碼+生日之月日4碼
# PDF_PASSWORD_TAISHIN_LEGACY_1=      # 舊密碼 1（若 2020 年前帳單解密失敗時填入）
# PDF_PASSWORD_TAISHIN_LEGACY_2=      # 舊密碼 2（可選）
# PDF_PASSWORD_UBOT=your-password
# PDF_PASSWORD_CATHAY=your-cathay-password
# PDF_PASSWORD_SINOPAC=your-sinopac-password
# PDF_PASSWORD_FUBON=your-national-id  # 身分證字號（National ID）

# -----------------------------------------------------------------------------
# FUBON web-fetch credentials（選填；unset → FUBON 自動下載停用）
# -----------------------------------------------------------------------------
# FUBON_NATIONAL_ID=A123456789
# FUBON_ROC_BIRTHDAY=0881010  # 民國年月日 7 碼（例：088年10月10日 = 0881010）
# FUBON_CAPTCHA_MAX_RETRIES=7          # 1-20；OCR + doLogin 迴圈最大重試次數
# FUBON_CAPTCHA_FALLBACK_LLM=false     # OCR 失敗後是否 fallback 至 Claude Vision
# FUBON_CAPTCHA_ARCHIVE_DIR=            # 設定後，成功驗證的 captcha JPEG 會自動存入此目錄（用於擴充 eval 資料集）
# ANTHROPIC_API_KEY=sk-ant-...         # 僅在 FUBON_CAPTCHA_FALLBACK_LLM=true 時需要
# FUBON_MANUAL_STAGING_DIR=./data/manual-staging/FUBON  # 手動下載 PDF 放置目錄（SPA 自動化完成前的 fallback）

# -----------------------------------------------------------------------------
# Frontend（Vite — VITE_ prefix required）
# -----------------------------------------------------------------------------
# Dev 留空即可：vite.config.ts 會把 /api 透過 proxy 轉到 VITE_API_PROXY_TARGET。
# 僅 production build 或連接非預設後端時才填 VITE_API_BASE。
# VITE_API_BASE=http://127.0.0.1:8000
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
