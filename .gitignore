# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# OpenSpec: only synced specs are version-controlled; changes/ is transient work
openspec/*
!openspec/specs/
!openspec/config.yaml

# Playwright snapshots & reports (local testing artifacts)
.playwright-cli/
test-results/
playwright-report/

# Logs
*.log
logs/
!logs/.gitkeep

# Environment
.env
.env.local
.env.*.local
.env.bak*
.env.prod
.env.prod.*
.env.staging
.env.staging.*
*.Zone.Identifier

# Backup files (never commit backups — they may contain real PII/secrets)
*.bak
*.bak.*
*.bak-*
backend/data/*.bak*

# Python
__pycache__/
*.pyc
*.pyo
*.so
*.pyd
.venv/
*.egg-info/

# Python tooling
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/
.pyright/

# SQLite
backend/data/*.db
backend/data/*.db-wal
backend/data/*.db-shm
*.db-journal

# Staging data (user downloads / manual processing, contains PII)
backend/data/staging/
backend/data/manual-staging/

# Scheduler runtime heartbeat（容器啟動時生成，內含 timestamp）
backend/data/scheduler-heartbeat

# Local data files: SSOT 為 config/，docker-entrypoint.sh 會從 *.example.yaml seed
backend/data/banks.yaml
backend/data/bank-code-registry.yaml
backend/data/categories.yaml

# Credentials (Gmail OAuth tokens)
backend/data/credentials.json
backend/data/token.json
credentials/

# Secrets (encryption keys, API tokens — never commit)
backend/data/secrets/

# Node.js
node_modules/
# pnpm content-addressable store（當 pnpm 無法寫入 global store 時會落在 cwd，
# 如 `docker compose run pnpm install` 從 /app 起 → 經 bind mount 進入 frontend/）
.pnpm-store/

# Vite cache
frontend/.vite/

# Build
dist/
build/

# Local config (使用 *.example.yaml 為範本，啟動時 entrypoint 會自動 seed）
config/banks.yaml
config/bank-code-registry.yaml
config/categories.yaml
!config/*.example.yaml

# Docker Compose：docker-compose.override.yml 為專案 dev 預設，已納入版控。
# 個人化客製請用 docker-compose.local.yml（本 gitignore）：
#   docker compose -f docker-compose.yaml -f docker-compose.override.yml -f docker-compose.local.yml up
docker-compose.local.yml

# Claude Code plan files
.claude/plans/

# Claude Code personal overrides (Gmail MCP, macOS shortcuts, etc.)
# settings.json is team-shared; settings.local.json is per-developer.
.claude/settings.local.json

# Claude Code runtime state（每次 session 啟動會改寫 sessionId/pid）
.claude/scheduled_tasks.lock

compact-notes/
backend/data/captcha-archive/
.gitnexus

# Claude Code session artifacts & generated workflow scripts (transient)
.claude/artifacts/
.claude/workflows/

# Working plan file (per-user CLAUDE.md convention: deleted on completion)
IMPLEMENTATION_PLAN.md

# Eval run outputs (fixtures + README tracked; results are transient)
evals/results/

# Tool-generated directories (auto-managed by npx/tooling, not version-controlled)
.agents/
.hyperweave/
.reports/
