# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# OpenSpec runtime output (keep changes/ tracked, ignore temp files)
openspec/.cache/
openspec/*.log

# Playwright snapshots (local testing artifacts)
.playwright-cli/

# Logs
*.log
logs/
!logs/.gitkeep

# Environment
.env
.env.local
.env.*.local
.env.bak*
*.Zone.Identifier

# Backup files (never commit backups — they may contain real PII/secrets)
*.bak
*.bak.*
*.bak-*
backend/data/*.bak*

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Python tooling
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/
.pyright/

# SQLite
backend/data/*.db
backend/data/*.db-wal
backend/data/*.db-shm
*.db-journal

# Staging data (user downloads, contains PII)
backend/data/staging/

# Credentials (Gmail OAuth tokens)
backend/data/credentials.json
backend/data/token.json
credentials/

# Node.js
node_modules/

# Build
dist/
build/

# Local config (use banks.example.yaml as template)
config/banks.yaml

# Docker Compose：docker-compose.override.yml 為專案 dev 預設，已納入版控。
# 個人化客製請用 docker-compose.local.yml（本 gitignore）：
#   docker compose -f docker-compose.yaml -f docker-compose.override.yml -f docker-compose.local.yml up
docker-compose.local.yml

# Claude Code plan files
.claude/plans/

# Claude Code personal overrides (Gmail MCP, macOS shortcuts, etc.)
# settings.json is team-shared; settings.local.json is per-developer.
.claude/settings.local.json

compact-notes/
