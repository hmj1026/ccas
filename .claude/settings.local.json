      "Bash(uv tool:*)",
      "Bash(python3:*)",
      "Bash(python -m pytest:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm vitest:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm exec:*)",
