{
  "permissions": {
    "allow": [
      "Bash(find /home/paul/projects/ccas -maxdepth 1 -type f \\\\\\(-name .* \\\\\\) ! -name .git ! -name .. ! -name .)",
      "Bash(find /home/paul/projects/ccas -maxdepth 2 \\\\\\(-name *.md -o -name *.txt -o -name *.yml -o -name *.yaml -o -name *.toml \\\\\\) ! -path */.git/*)",
      "Bash(openspec *)",
      "Bash(uv sync*)",
      "Bash(uv add *)",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff *)",
      "Bash(uv run pyright*)",
      "Bash(uv run alembic *)",
      "Bash(uv run fastapi dev*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ]
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/paul/.claude/scripts/hooks/ccas-python-lint.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running Python lint & security checks...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash -c '[[ \"$1\" == *models*.py ]] && { grep -q \"__tablename__\" \"$1\" || echo \"[Hook] WARNING: __tablename__ not found\"; grep -q \"Base\" \"$1\" || echo \"[Hook] WARNING: does not inherit from Base\"; echo \"[Hook] REMINDER: Run uv run alembic revision --autogenerate -m description\"; }' _ \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Validating SQLAlchemy model...",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/paul/.claude/scripts/hooks/ccas-python-lint.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running Python lint & security checks...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash -c '[[ \"$1\" == *models*.py ]] && { grep -q \"__tablename__\" \"$1\" || echo \"[Hook] WARNING: __tablename__ not found\"; grep -q \"Base\" \"$1\" || echo \"[Hook] WARNING: does not inherit from Base\"; }' _ \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Validating SQLAlchemy model...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash -c '[[ \"$1\" == test_*.py ]] && cd /home/paul/projects/ccas && uv run pytest \"$1\" -x --tb=short 2>&1 | tail -30' _ \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running test to confirm RED state...",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/paul/.claude/scripts/hooks/ccas-session-retrospective.sh",
            "timeout": 10,
            "statusMessage": "Running session retrospective...",
            "async": false
          }
        ]
      }
    ]
  }
}
