      "Bash(curl -s -H 'Authorization: Bearer 123456' 'http://127.0.0.1:8765/api/bills?page=1&page_size=1000')",
      "Bash(curl -s -H 'Authorization: Bearer 123456' 'http://127.0.0.1:8765/api/bills?page=1&page_size=__TRACKED_VAR__')",
      "Bash(python -c ':*)",
      "Bash(kill 15433)",
      "Bash(pip show:*)",
      "Bash(rm -rf backend/data/staging)",
      "Bash(rm -f backend/data/ccas.db backend/data/ccas.db-shm backend/data/ccas.db-wal backend/data/credentials.json backend/data/token.json)",
      "Bash(mkdir -p backend/data/staging)",
      "Bash(touch backend/data/staging/.gitkeep)",
      "Bash(brew install:*)",
      "Bash(gitleaks detect:*)",
      "Bash(head -50 /Users/paul/Project/ccas/backend/src/ccas/api/*.py)",
      "Bash(head -3 /Users/paul/Project/ccas/.claude/rules/*.md)",
      "Bash(bash -n scripts/start.sh)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-python-lint.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running Python lint & security checks...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-sqlalchemy-model-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Validating SQLAlchemy model...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-frontend-lint.sh \"$filePath\"",
            "timeout": 15,
            "statusMessage": "Running frontend lint...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-alembic-migration-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Checking Alembic migration safety...",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-python-lint.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running Python lint & security checks...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-sqlalchemy-model-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Validating SQLAlchemy model...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-tdd-red-check.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running test to confirm RED state...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-frontend-lint.sh \"$filePath\"",
            "timeout": 15,
            "statusMessage": "Running frontend lint...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-alembic-migration-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Checking Alembic migration safety...",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-session-retrospective.sh",
            "timeout": 10,
            "statusMessage": "Running session retrospective...",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "pyright-lsp@claude-plugins-official": true
  }
}
