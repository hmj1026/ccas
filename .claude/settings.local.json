{
  "permissions": {
    "allow": [
      "Bash(openspec *)",
      "Bash(uv sync*)",
      "Bash(uv add *)",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff *)",
      "Bash(uv run pyright*)",
      "Bash(uv run alembic *)",
      "Bash(uv run fastapi dev*)",
      "Bash(uv run:*)",
      "Bash(uv pip:*)",
      "Bash(uv tool:*)",
      "Bash(python3:*)",
      "Bash(python -m pytest:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm vitest:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm list:*)",
      "Bash(pnpm build:*)",
      "Bash(node:*)",
      "Bash(docker build:*)",
      "Bash(docker run:*)",
      "Bash(docker rmi:*)",
      "Bash(docker compose:*)",
      "Bash(docker --version)",
      "Bash(git:*)",
      "Bash(gh run:*)",
      "Bash(bash ./scripts/*)",
      "Bash(./scripts/*)",
      "Bash(shellcheck:*)",
      "Bash(chmod +x:*)",
      "Bash(cx:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(xargs:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(rm:*)",
      "Bash(command -v:*)",
      "Bash(curl -s http://127.0.0.1:*)",
      "Bash(netstat -tlnp)",
      "Bash(lsof -nP -iTCP:5173 -sTCP:LISTEN)",
      "Bash(kill %1)",
      "Bash(pkill -f \"uvicorn ccas.api\")",
      "Bash(uv --version)",
      "Bash(tesseract --version)",
      "Bash(dpkg -l)",
      "Bash(sudo apt-get:*)",
      "Bash(sudo chown:*)",
      "Bash(npx eslint:*)",
      "Bash(bash -n scripts/pre-commit.sh)",
      "Bash(bash -n scripts/pre-push.sh)",
      "Bash(bash -n scripts/setup-hooks.sh)",
      "Bash(bash -n scripts/setup.sh)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-python-lint.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running Python lint & security checks...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-sqlalchemy-model-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Validating SQLAlchemy model...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-frontend-lint.sh \"$filePath\"",
            "timeout": 15,
            "statusMessage": "Running frontend lint...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-alembic-migration-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Checking Alembic migration safety...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-skill-sync-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Checking skill platform parity...",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-python-lint.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running Python lint & security checks...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-sqlalchemy-model-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Validating SQLAlchemy model...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-tdd-red-check.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running test to confirm RED state...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-frontend-lint.sh \"$filePath\"",
            "timeout": 15,
            "statusMessage": "Running frontend lint...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-alembic-migration-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Checking Alembic migration safety...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-skill-sync-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Checking skill platform parity...",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-session-retrospective.sh",
            "timeout": 10,
            "statusMessage": "Running session retrospective...",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "pyright-lsp@claude-plugins-official": true
  }
}
