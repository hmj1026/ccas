      "Bash(curl -s http://127.0.0.1:*)",
      "Bash(netstat -tlnp)",
      "Bash(lsof -nP -iTCP:5173 -sTCP:LISTEN)",
      "Bash(kill %1)",
      "Bash(pkill -f \"uvicorn ccas.api\")",
      "Bash(uv --version)",
      "Bash(tesseract --version)",
      "Bash(dpkg -l)",
