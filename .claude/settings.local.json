{
  "permissions": {
    "allow": [
      "Bash(find /home/paul/projects/ccas -maxdepth 1 -type f \\\\\\(-name .* \\\\\\) ! -name .git ! -name .. ! -name .)",
      "Bash(find /home/paul/projects/ccas -maxdepth 2 \\\\\\(-name *.md -o -name *.txt -o -name *.yml -o -name *.yaml -o -name *.toml \\\\\\) ! -path */.git/*)",
      "Bash(openspec *)",
      "Bash(uv sync*)",
      "Bash(uv add *)",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff *)",
      "Bash(uv run pyright*)",
      "Bash(uv run alembic *)",
      "Bash(uv run fastapi dev*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(uv run:*)",
      "Bash(cx overview:*)",
      "Bash(cx d:*)",
      "Bash(uv pip:*)",
      "Bash(cx o:*)",
      "Bash(cx symbols:*)",
      "Bash(cx s:*)",
      "Bash(find:*)",
      "Bash(xargs cat:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-python-lint.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running Python lint & security checks...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-sqlalchemy-model-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Validating SQLAlchemy model...",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-python-lint.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running Python lint & security checks...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-sqlalchemy-model-check.sh \"$filePath\"",
            "timeout": 5,
            "statusMessage": "Validating SQLAlchemy model...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-tdd-red-check.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Running test to confirm RED state...",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ccas-session-retrospective.sh",
            "timeout": 10,
            "statusMessage": "Running session retrospective...",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "pyright-lsp@claude-plugins-official": true
  }
}
