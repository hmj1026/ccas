      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\('INSTRUCTION:', d.get\\('instruction',''\\)[:800]\\); print\\('---TEMPLATE---'\\); print\\(d.get\\('template',''\\)[:1500]\\); print\\('OUTPUT:', d.get\\('outputPath'\\)\\)\")",
