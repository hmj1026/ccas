# =============================================================================
# CCAS prod env 範本（pull-only / 發布版）
# =============================================================================
# 用法：
#   curl -O <release_url>/docker-compose.yml
#   curl -O <release_url>/example.env
#   cp example.env .env
#   <編輯 .env 必填欄位>
#   docker compose pull
#   docker compose up -d
#
# 規則（與根目錄 .env.example 同步）：
#   - `KEY=`        → 必填：未設定會在啟動時 fail-fast
#   - `KEY=value`   → 選填：未設定使用預設值
#   - `# KEY=...`   → 完全選填：保留範例供使用者啟用
# =============================================================================

# -----------------------------------------------------------------------------
# Docker / 部署（必填段）
# -----------------------------------------------------------------------------
CCAS_VERSION=release                  # GHCR image tag；建議 production 改為精確版本如 v0.1.0
REPO_OWNER=                           # 必填：GHCR 命名空間（GitHub repo owner，如 hmj1026）
CCAS_DATA_LOCATION=./data             # 持久化資料目錄（SQLite / staging / secrets / redis dump）
CCAS_CONFIG_LOCATION=./config         # banks.yaml 等 yaml 配置目錄；未填會自動 seed 預設值
CCAS_LOG_LOCATION=./logs              # 各 service log 檔目錄
CCAS_PORT=8080                        # Proxy 對外 host port（即 Web UI 入口）；範圍 1-65535
# PUBLIC_BASE_URL=http://localhost:8080 # OAuth redirect URI 用；自訂 CCAS_PORT / 網域時同步調整

# -----------------------------------------------------------------------------
# Database（沿用容器內預設路徑；prod compose 已將 SQLite 落地至 ${CCAS_DATA_LOCATION}/ccas.db）
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:////data/ccas.db

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# API_TOKEN：未設定時 entrypoint 自動產生 32-byte hex 並落地 ${CCAS_DATA_LOCATION}/secrets/api-token；
# 顯式設為空字串會被 check-env.sh 報錯（避免「忘了取消註解」造成的弱密碼）
# API_TOKEN=
API_HOST=0.0.0.0
API_PORT=8000
# FRONTEND_ORIGINS：CORS 來源白名單（逗號分隔）。
#   - prod 同源（前後端皆走 ${CCAS_PORT}）→ 留空即可（prod compose 走單一 proxy 入口）
#   - 開發本機雙 server 才需要：localhost:5173,localhost:8080
FRONTEND_ORIGINS=

# -----------------------------------------------------------------------------
# Gmail（必填；提供 OAuth credentials.json 後再填）
# -----------------------------------------------------------------------------
GMAIL_CREDENTIALS_PATH=/data/credentials.json
GMAIL_TOKEN_PATH=/data/token.json
STAGING_DIR=/data/staging

# -----------------------------------------------------------------------------
# Telegram（選填；填妥後 bot service 自動啟用，不需 profile）
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890

# -----------------------------------------------------------------------------
# Redis（容器網路內部使用）
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# REDIS_MAXMEMORY=256mb
# REDIS_MAXMEMORY_POLICY=allkeys-lru

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Bank PDF Passwords（per-bank；填妥才能解密該銀行帳單）
# -----------------------------------------------------------------------------
# PDF_PASSWORD_CTBC=your-ctbc-password
# PDF_PASSWORD_ESUN=your-password
# PDF_PASSWORD_TAISHIN=your-password
# PDF_PASSWORD_UBOT=your-password
# PDF_PASSWORD_CATHAY=your-password
# PDF_PASSWORD_SINOPAC=your-password
# PDF_PASSWORD_FUBON=your-national-id

# -----------------------------------------------------------------------------
# FUBON 自動下載（選填）
# -----------------------------------------------------------------------------
# FUBON_NATIONAL_ID=A123456789
# FUBON_ROC_BIRTHDAY=0881010
# FUBON_CAPTCHA_FALLBACK_LLM=false
# ANTHROPIC_API_KEY=sk-ant-...
